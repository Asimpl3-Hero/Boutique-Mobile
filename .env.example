# Backend base URL (no trailing slash).
#   Android emulator:  http://10.0.2.2:3000
#   iOS simulator:     http://localhost:3000
#   Physical device:   http://localhost:3000 with `adb reverse tcp:3000 tcp:3000`,
#                      or http://<host-LAN-IP>:3000
API_URL=http://10.0.2.2:3000

# Payments provider (public values only — never commit secrets).
PAYMENTS_PUBLIC_KEY=
# Left empty on purpose: the acceptance token is resolved dynamically at checkout.
PAYMENTS_ACCEPTANCE_TOKEN=
